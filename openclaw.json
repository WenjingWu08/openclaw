{
  "browser": {
    "enabled": true,
    "executablePath": "${BROWSER_PATH}",
    "defaultProfile": "openclaw"
  },
  "acp": {
    "enabled": true,
    "dispatch": {
      "enabled": true
    },
    "backend": "acpx",
    "defaultAgent": "opencode",
    "allowedAgents": [
      "pi",
      "claude",
      "codex",
      "opencode",
      "gemini"
    ],
    "maxConcurrentSessions": 8,
    "stream": {
      "coalesceIdleMs": 300,
      "maxChunkChars": 1200
    },
    "runtime": {
      "ttlMinutes": 120
    }
  },
  "models": {
    "mode": "merge",
    "providers": {
      "${LLM_PROVIDER_ID}": {
        "baseUrl": "${LLM_BASE_URL}",
        "auth": "api-key",
        "api": "openai-completions",
        "models": [
          {
            "id": "${LLM_MODEL_ID}",
            "name": "${LLM_MODEL_ID}",
            "api": "openai-completions",
            "reasoning": false,
            "input": [
              "text"
            ],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 128000,
            "maxTokens": 50000
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "${LLM_PROVIDER_ID}/${LLM_MODEL_ID}",
        "fallbacks": []
      },
      "models": {
        "${LLM_PROVIDER_ID}/${LLM_MODEL_ID}": {}
      },
      "workspace": "~/.openclaw/workspace",
      "compaction": {
        "mode": "safeguard"
      },
      "blockStreamingDefault": "off",
      "heartbeat": {
        "every": "30m",
        "target": "last"
      },
      "maxConcurrent": 4,
      "subagents": {
        "maxConcurrent": 8
      },
      "sandbox": {
        "mode": "off"
      }
    }
  },
  "tools": {
    "profile": "full",
    "allow": [
      "*"
    ],
    "web": {
      "search": {
        "enabled": true,
        "provider": "brave",
        "maxResults": 5,
        "timeoutSeconds": 30
      }
    },
    "sessions": {
      "visibility": "all"
    }
  },
  "messages": {
    "ackReactionScope": "group-mentions"
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "hooks": {
    "internal": {
      "enabled": true,
      "entries": {
        "session-memory": {
          "enabled": true
        },
        "command-logger": {
          "enabled": true
        },
        "boot-md": {
          "enabled": true
        }
      }
    }
  },
  "channels": {
    "whatsapp": {
      "enabled": true,
      "dmPolicy": "allowlist",
      "allowFrom": [
        "${WHATSAPP_ALLOW_FROM}"
      ],
      "groupPolicy": "open",
      "debounceMs": 0,
      "mediaMaxMb": 50
    },
    "telegram": {
      "enabled": true,
      "dmPolicy": "pairing",
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "groupPolicy": "open",
      "streaming": "partial"
    },
    "slack": {
      "mode": "socket",
      "webhookPath": "/slack/events",
      "enabled": true,
      "botToken": "${SLACK_BOT_TOKEN}",
      "appToken": "${SLACK_APP_TOKEN}",
      "userTokenReadOnly": true,
      "groupPolicy": "allowlist",
      "nativeStreaming": true,
      "streaming": "partial"
    },
    "feishu": {
      "enabled": true,
      "appId": "${FEISHU_APP_ID}",
      "appSecret": "${FEISHU_APP_SECRET}",
      "domain": "feishu",
      "connectionMode": "websocket",
      "requireMention": true,
      "mediaMaxMb": 30,
      "renderMode": "auto",
      "tools": {
        "perm": true
      },
      "accounts": {
        "default": {
          "appId": "${FEISHU_APP_ID}",
          "appSecret": "${FEISHU_APP_SECRET}",
          "botName": "FeishuAI",
          "dmPolicy": "pairing",
          "groupPolicy": "open"
        }
      },
      "stream": false
    }
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "loopback",
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    },
    "nodes": {
      "denyCommands": [
        "camera.snap",
        "camera.clip",
        "screen.record",
        "calendar.add",
        "contacts.add",
        "reminders.add"
      ]
    }
  },
  "skills": {
    "install": {
      "nodeManager": "pnpm"
    }
  },
  "meta": {
    "lastTouchedVersion": "2026.3.22",
    "lastTouchedAt": "2026-03-23T15:07:12.135Z"
  }
}
